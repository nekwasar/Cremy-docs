# ========================================
# API Keys & Secrets
# ========================================
# Uncomment and fill values as you acquire keys.
# Leave commented/empty — the affected feature gracefully disables.

# JWT (override dev defaults)
# JWT_SECRET=
# REFRESH_SECRET=

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=

# Email / SMTP (Brevo, SendGrid, etc.)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_KEY=

# Flutterwave
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_ENCRYPTION_KEY=
# FLUTTERWAVE_WEBHOOK_SECRET=
# FLUTTERWAVE_ENVIRONMENT=sandbox

# Paystack
# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_SECRET_KEY=
# PAYSTACK_ENVIRONMENT=sandbox

# PayPal
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_ENVIRONMENT=sandbox

# AI
# AI_API_KEY=
# AI_MODEL=
# AI_PROVIDER=
# WHISPER_API_URL=

# OAuth state encryption
# OAUTH_STATE_SECRET=
